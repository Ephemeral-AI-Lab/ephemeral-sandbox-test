{
  "name": "ephemeralos-benchmark-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixture": "playwright test --project=fixture",
    "test:real-backend": "node ./tests/browser/real-backend/run-real-backend.mjs",
    "test:real-backend:smoke": "BENCHMARK_REAL_BACKEND_STAGE=small node ./tests/browser/real-backend/run-real-backend.mjs",
    "test:real-backend:medium": "BENCHMARK_REAL_BACKEND_STAGE=medium node ./tests/browser/real-backend/run-real-backend.mjs"
  },
  "dependencies": {
    "@mantine/core": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "uplot": "1.6.32",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0 || >=24.0.0"
  }
}
