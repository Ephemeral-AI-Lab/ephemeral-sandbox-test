  "test": {
    "bytes_read": 1720,
    "content": "import test from 'node:test';\nimport assert from 'node:assert/strict';\nimport { readFile } from 'node:fs/promises';\n\nconst registry = await readFile(new URL('../src/registry.js', import.meta.url), 'utf8');\nconst config = await readFile(new URL('../src/config.js', import.meta.url), 'utf8');\n\nconst expectedPolicy = {\n  freeShippingCents: 6000,\n  standardShippingCents: 650,\n  taxRate: 0.075,\n  checkoutRetry: 'pending',\n};\n\ntest('published configuration matches the shared policy', () => Object.entries(expectedPolicy).forEach(([key, value]) => assert.ok(config.includes(`${key}: ${typeof value === 'string' ? `'${value}'` : value}`))));\n\ntest('A01 Foundation contribution is ready', () => assert.match(registry, /A01: \\{.*status: 'ready'/));\ntest('A02 Design system contribution is ready', () => assert.match(registry, /A02: \\{.*status: 'ready'/));\ntest('A03 Product data contribution is ready', () => assert.match(registry, /A03: \\{.*status: 'ready'/));\ntest('A04 Catalog and PDP contribution is ready', () => assert.match(registry, /A04: \\{.*status: 'ready'/));\ntest('A05 Search and facets contribution is ready', () => assert.match(registry, /A05: \\{.*status: 'ready'/));\ntest('A06 Cart and pricing contribution is ready', () => assert.match(registry, /A06: \\{.*status: 'ready'/));\ntest('A07 Wishlist contribution is ready', () => assert.match(registry, /A07: \\{.*status: 'ready'/));\ntest('A08 Checkout contribution is ready', () => assert.match(registry, /A08: \\{.*status: 'ready'/));\ntest('A09 Accessibility and performance contribution is ready', () => assert.match(registry, /A09: \\{.*status: 'ready'/));\ntest('A10 Integration QA contribution is ready', () => assert.match(registry, /A10: \\{.*status: 'ready'/));",
